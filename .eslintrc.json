{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "eqeqeq": ["error", "always"],
    "curly": ["error", "all"],
    "no-var": "error",
    "prefer-const": "error",
    "no-multiple-empty-lines": ["error", { "max": 2 }],
    "indent": ["off"],
    "linebreak-style": ["off"],
    "quotes": ["off"],
    "semi": ["off"]
  },
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "build/",
    "static/js/admin.js",
    "templates/*.html"
  ]
}
