# Git
.git
.gitignore

# Python
__pycache__
*.py[cod]
*$py.class
*.so
.Python
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache
.venv/
venv/
env/

# 数据目录（容器中会自动创建）
data/
*.db
*.log

# IDE
.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# 文档
*.md
!README.md

# 脚本（保留 install-browser.sh 用于精简版镜像）
scripts/*
!scripts/install-browser.sh
start.sh

# 其他
docker-compose*.yml
Dockerfile*
Makefile
.dockerignore
.gitignore

# ==================== 敏感信息（IMPORTANT）====================
# 环境变量文件
.env
.env.local
.env.*.local

# 配置文件（可能包含敏感信息）
config/config.yaml
config/*.yaml
!config/config.example.yaml

# 密钥和证书
*.pem
*.key
*.crt
secrets/
credentials/

# 备份文件
*.backup
*.bak
*~
