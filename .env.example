# zhihusync 环境变量配置
# 复制此文件为 .env 并填写你的配置

# ============================================
# 必填配置
# ============================================

# 知乎用户ID (必填)
# 从你的知乎个人主页 URL 获取，例如 https://www.zhihu.com/people/xxx
ZHIHU_USER_ID=your_user_id_here

# ============================================
# 可选配置
# ============================================

# 浏览器类型 (auto/chromium/firefox/webkit，默认 auto 自动检测)
# NAS/Docker 环境建议：如果 Chromium 有问题，尝试 firefox
PLAYWRIGHT_BROWSER=auto

# Playwright 下载镜像（国内用户建议设置）
PLAYWRIGHT_DOWNLOAD_HOST=https://npmmirror.com/mirrors/playwright

# 扫描间隔 (分钟，默认 60)
SCAN_INTERVAL=60

# 无头模式 (默认 true，调试时可设为 false)
HEADLESS=true

# 日志级别 (DEBUG/INFO/WARNING/ERROR，默认 INFO)
LOG_LEVEL=INFO

# ============================================
# 端口配置 (docker-compose.yml 中已设置)
# ============================================
# Web 管理界面: http://localhost:6067
# Nginx 静态文件: http://localhost:6068 (可选)
